{
  "name": "vite-nana-sprite",
  "version": "0.1.0",
  "description": "Vite plugin + nana-sprite custom element for CSS sprite sheets with proportional frame scaling",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.js"
      },
      "require": {
        "types": "./dist/runtime.d.cts",
        "default": "./dist/runtime.cjs"
      }
    },
    "./register": {
      "types": "./register-types.d.ts",
      "import": "./dist/register.js",
      "require": "./dist/register.cjs"
    },
    "./runtime/register": {
      "types": "./register-types.d.ts",
      "import": "./dist/register.js",
      "require": "./dist/register.cjs"
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./vue/NanaSprite.vue": "./vue/NanaSprite.vue",
    "./register-types": "./register-types.d.ts"
  },
  "files": [
    "dist",
    "vue",
    "register-types.d.ts",
    "src/virtual-module.d.ts"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build",
    "playground": "pnpm run build && pnpm -C playground dev"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "sprite",
    "sprite-sheet",
    "web-components"
  ],
  "license": "MIT",
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "image-size": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "react": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.1.0"
  },
  "packageManager": "pnpm@10.6.5+sha512.cdf928fca20832cd59ec53826496e7e49fded3c436dd7512d3825366d7e84d41"
}
