{
  "name": "vite-nana-sprite",
  "version": "0.1.1",
  "description": "Vite plugin + Vue / React components for CSS sprite sheets with proportional frame scaling",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rupiong/vite-nanaSprite.git"
  },
  "homepage": "https://github.com/Rupiong/vite-nanaSprite#readme",
  "bugs": {
    "url": "https://github.com/Rupiong/vite-nanaSprite/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.js"
      },
      "require": {
        "types": "./dist/runtime.d.cts",
        "default": "./dist/runtime.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./vue/NanaSprite.vue": "./vue/NanaSprite.vue",
    "./register-types": "./register-types.d.ts"
  },
  "files": [
    "dist",
    "vue",
    "register-types.d.ts",
    "src/virtual-module.d.ts"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build",
    "playground": "pnpm run build && pnpm -C playground dev"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "sprite",
    "sprite-sheet",
    "vue",
    "react"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "vite": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "image-size": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.6.5+sha512.cdf928fca20832cd59ec53826496e7e49fded3c436dd7512d3825366d7e84d41"
}
